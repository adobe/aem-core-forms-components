{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://adobe.com/aem/forms/authoring-schema/formcontainer",
  "title": "FormContainer JCR Authoring Properties (flattened for test validation)",
  "description": "Inlined/flattened version of formcontainer.authoring.schema.yaml + container.authoring.schema.yaml + base.authoring.schema.yaml. All submission and auto-save properties are FLAT JCR properties on this node — fd:submit and fd:autoSave are JSON model output groupings only.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "name":           { "type": "string" },
    "dataRef":        { "type": ["string", "null"] },
    "id":             { "type": "string" },
    "fieldType":      { "type": "string" },
    "visible":        { "type": "boolean" },
    "enabled":        { "type": "boolean" },
    "description":    { "type": "string" },
    "tooltip":        { "type": "string" },
    "tooltipVisible": { "type": "boolean" },
    "lang":           { "type": "string" },
    "langDisplayValue": { "type": "string" },
    "fd:viewType":    { "type": "string" },
    "unboundFormElement": { "type": "boolean" },
    "type":           { "type": "string" },
    "required":       { "type": "boolean" },
    "validationExpression": { "type": "string" },
    "assistPriority": { "type": "string" },
    "custom":         { "type": "string" },
    "repeatable":     { "type": "boolean" },
    "minOccur":       { "type": "integer" },
    "maxOccur":       { "type": "integer" },
    "minItems":       { "type": "integer" },
    "maxItems":       { "type": "integer" },
    "lazy":           { "type": "boolean" },
    "fragmentPath":   { "type": "string" },
    "fd:enableAutoSave": { "type": "boolean" },
    "fd:autoSaveStrategyType": {
      "type": "string",
      "enum": ["time", "fieldFocus"]
    },
    "fd:autoSaveInterval": { "type": "integer" },
    "actionType":     { "type": "string" },
    "actionName":     { "type": "string" },
    "mailto":         { "type": "string" },
    "from":           { "type": "string" },
    "subject":        { "type": "string" },
    "cc":             { "type": "string" },
    "bcc":            { "type": "string" },
    "spreadsheetUrl": { "type": "string" },
    "thankYouOption": {
      "type": "string",
      "enum": ["message", "redirect"]
    },
    "thankYouMessage": { "type": "string" },
    "thankyouMessage": { "type": "string" },
    "redirect":       { "type": "string" },
    "prefillService": { "type": "string" },
    "specVersion":    { "type": "string" },
    "clientLibRef":   { "type": "string" }
  }
}
