{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://adobe.com/aem/forms/authoring-schema/dropdown",
  "title": "Dropdown JCR Authoring Properties (flattened for test validation)",
  "description": "Inlined/flattened version of dropdown.authoring.schema.yaml + field.authoring.schema.yaml + base.authoring.schema.yaml. Used in unit tests via Utils.testJcrSchemaValidation.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "name": { "type": "string" },
    "dataRef": { "type": ["string", "null"] },
    "id": { "type": "string" },
    "fieldType": {
      "type": "string",
      "enum": [
        "text-input", "number-input", "date-input", "datetime-input",
        "file-input", "multiline-input", "drop-down", "radio-group",
        "checkbox-group", "checkbox", "switch", "plain-text", "button",
        "panel", "image", "email", "captcha", "tel"
      ]
    },
    "visible": { "type": "boolean" },
    "enabled": { "type": "boolean" },
    "jcr:title": { "type": "string" },
    "hideTitle": { "type": "boolean" },
    "isTitleRichText": { "type": "boolean" },
    "description": { "type": "string" },
    "tooltip": { "type": "string" },
    "tooltipVisible": { "type": "boolean" },
    "type": {
      "type": "string",
      "enum": ["string", "number", "integer", "boolean", "string[]", "number[]", "boolean[]", "file", "file[]", "object", "array"]
    },
    "required": { "type": "boolean" },
    "mandatoryMessage": { "type": "string" },
    "validationExpression": { "type": "string" },
    "validateExpMessage": { "type": "string" },
    "assistPriority": { "type": "string", "enum": ["description", "title", "name", "custom"] },
    "custom": { "type": "string" },
    "repeatable": { "type": "boolean" },
    "minOccur": { "type": "integer" },
    "maxOccur": { "type": "integer" },
    "minItems": { "type": "integer" },
    "maxItems": { "type": "integer" },
    "minItemsMessage": { "type": "string" },
    "maxItemsMessage": { "type": "string" },
    "uniqueItemsMessage": { "type": "string" },
    "dorExclusion": { "type": "boolean" },
    "dorColspan": { "type": "string" },
    "dorBindRef": { "type": "string" },
    "dorExcludeTitle": { "type": "boolean" },
    "dorExcludeDescription": { "type": "boolean" },
    "dorNumCols": { "type": "integer" },
    "dorLayoutType": { "type": "string" },
    "dorTemplateRef": { "type": "string" },
    "dorType": { "type": "string" },
    "fd:formType": { "type": "string" },
    "lang": { "type": "string" },
    "langDisplayValue": { "type": "string" },
    "fd:channel": { "type": "string" },
    "fd:viewType": { "type": "string" },
    "unboundFormElement": { "type": "boolean" },
    "readOnly": { "type": "boolean" },
    "placeholder": { "type": "string" },
    "displayFormat": { "type": "string" },
    "fd:customDisplayFormat": { "type": "string" },
    "editFormat": { "type": "string" },
    "displayValueExpression": { "type": "string" },
    "dataFormat": { "type": "string" },
    "minLength": { "type": "integer" },
    "maxLength": { "type": "integer" },
    "minLengthMessage": { "type": "string" },
    "maxLengthMessage": { "type": "string" },
    "pattern": { "type": "string" },
    "validatePictureClauseMessage": { "type": "string" },
    "exclusiveMinimum": { "type": "boolean" },
    "exclusiveMaximum": { "type": "boolean" },
    "minimumDate": { "type": "string" },
    "maximumDate": { "type": "string" },
    "minimumDateTime": { "type": "string" },
    "maximumDateTime": { "type": "string" },
    "minimumMessage": { "type": "string" },
    "maximumMessage": { "type": "string" },
    "typeMessage": { "type": "string" },
    "formatMessage": { "type": "string" },
    "stepMessage": { "type": "string" },
    "fd:emptyValue": { "type": "string", "enum": ["null", "undefined", ""] },
    "fd:multiDefaultValues": {
      "type": "array",
      "items": { "type": ["string", "number", "boolean"] }
    },
    "enum": {
      "type": "array",
      "items": { "type": ["string", "number", "boolean"] }
    },
    "enumNames": {
      "type": "array",
      "items": { "type": "string" }
    },
    "multiSelect": { "type": "boolean" },
    "enforceEnum": { "type": "boolean" },
    "enforceEnumMessage": { "type": "string" },
    "areOptionsRichText": { "type": "boolean" }
  }
}
