<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:granite="http://www.adobe.com/jcr/granite/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Date Input">
    <items jcr:primaryType="nt:unstructured">
        <field
            jcr:primaryType="nt:unstructured"
            jcr:title="Base"
            id="af2_dateinput"
            longTitle="Base"
            propertySheet="/mnt/overlay/fd/af/components/stylePropertySheet/common">
            <items jcr:primaryType="nt:unstructured">
                <widgetAndText
                    jcr:primaryType="nt:unstructured"
                    jcr:title="Date Input"
                    id="af2_dateinputwidgetandtext"
                    cssSelector=".cmp-adaptiveform-dateinput"
                    longTitle="Date Input Widget"
                    propertySheet="/mnt/overlay/fd/af/components/stylePropertySheet/common"
                    secondarySelectors="af2_guideContainer:af2_widgetAndText">
                    <items jcr:primaryType="nt:unstructured">
                        <dateinputLabelContainer
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Label Container"
                            id="af2_dateinputlabelcontainer"
                            cssSelector=".cmp-adaptiveform-dateinput__label-container"
                            longTitle="Date Input Label Container"
                            propertySheet="/mnt/overlay/fd/af/components/stylePropertySheet/common">
                            <items jcr:primaryType="nt:unstructured">
                                <dateinputLabel
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Label"
                                    id="af2_dateinputlabel"
                                    cssSelector=".cmp-adaptiveform-dateinput__label"
                                    longTitle="Date Input Label"
                                    propertySheet="/mnt/overlay/fd/af/components/stylePropertySheet/common">
                                    <states jcr:primaryType="nt:unstructured">
                                        <hover
                                            jcr:primaryType="nt:unstructured"
                                            jcr:title="Hover"
                                            cssSelector=".cmp-adaptiveform-dateinput__label:hover"/>
                                        <focus
                                            jcr:primaryType="nt:unstructured"
                                            jcr:title="Focus"
                                            cssSelector=".cmp-adaptiveform-dateinput__label:focus"/>
                                    </states>
                                </dateinputLabel>
                                <dateinputHelpIcon
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Help Icon"
                                    id="af2_dateinputhelpicon"
                                    cssSelector=".cmp-adaptiveform-dateinput__questionmark"
                                    longTitle="Date Input Help Icon"
                                    propertySheet="/mnt/overlay/fd/af/components/stylePropertySheet/common"
                                    secondarySelectors="af2_guideContainer:af2_helpicon">
                                    <states jcr:primaryType="nt:unstructured">
                                        <focus
                                            jcr:primaryType="nt:unstructured"
                                            jcr:title="Focus"
                                            cssSelector=".cmp-adaptiveform-dateinput__questionmark:focus"/>
                                        <hover
                                            jcr:primaryType="nt:unstructured"
                                            jcr:title="Hover"
                                            cssSelector=".cmp-adaptiveform-dateinput__questionmark:hover"/>
                                        <disabled
                                            jcr:primaryType="nt:unstructured"
                                            jcr:title="Disabled"
                                            cssSelector=".cmp-adaptiveform-dateinput__questionmark:disabled"/>
                                    </states>
                                </dateinputHelpIcon>
                            </items>
                            <states jcr:primaryType="nt:unstructured">
                                <disabled
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Disabled"
                                    cssSelector=".cmp-adaptiveform-dateinput__label-container:disabled"/>
                                <hover
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Hover"
                                    cssSelector=".cmp-adaptiveform-dateinput__label-container:hover"/>
                                <focus
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Focus"
                                    cssSelector=".cmp-adaptiveform-dateinput__label-container:focus"/>
                            </states>
                        </dateinputLabelContainer>
                        <dateinputWidget
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Date Input Widget"
                            id="af2_dateinputwidget"
                            cssSelector=".cmp-adaptiveform-dateinput__widget"
                            longTitle="Date Input Sub-field"
                            propertySheet="/mnt/overlay/fd/af/components/stylePropertySheet/common"
                            secondarySelectors="af2_guideContainer:af2_widgetAndText">
                            <states jcr:primaryType="nt:unstructured">
                                <focus
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Focus"
                                    cssSelector=".cmp-adaptiveform-dateinput__widget:focus"/>
                                <hover
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Hover"
                                    cssSelector=".cmp-adaptiveform-dateinput__widget:hover"/>
                                <disabled
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Disabled"
                                    cssSelector=".cmp-adaptiveform-dateinput__widget:disabled"/>
                                <mandatory
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Mandatory"
                                    cssSelector=".cmp-adaptiveform-dateinput__widget:required"/>
                            </states>
                        </dateinputWidget>
                        <dateinputDescriptionShort
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Short Description"
                            id="af2_dateinputdescriptionshort"
                            cssSelector=".cmp-adaptiveform-dateinput__shortdescription"
                            longTitle="Date Input Short Description"
                            propertySheet="/mnt/overlay/fd/af/components/stylePropertySheet/common"/>
                        <dateinputDescriptionLong
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Long Description"
                            id="af2_dateinputdescriptionlong"
                            cssSelector=".cmp-adaptiveform-dateinput__longdescription"
                            longTitle="Date Input Long Description"
                            propertySheet="/mnt/overlay/fd/af/components/stylePropertySheet/common">
                            <states jcr:primaryType="nt:unstructured">
                                <focus
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Focus"
                                    cssSelector=".cmp-adaptiveform-dateinput__longdescription:focus"/>
                                <hover
                                    jcr:primaryType="nt:unstructured"
                                    jcr:title="Hover"
                                    cssSelector=".cmp-adaptiveform-dateinput__longdescription:hover"/>
                            </states>
                        </dateinputDescriptionLong>
                        <dateinputErrorMessage
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Error Message"
                            id="af2_dateinputerrormessage"
                            cssSelector=".cmp-adaptiveform-dateinput__errormessage"
                            longTitle="Date Input Error Message"
                            propertySheet="/mnt/overlay/fd/af/components/stylePropertySheet/common"/>
                    </items>
                    <states jcr:primaryType="nt:unstructured">
                        <focus
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Focus"
                            cssSelector=".cmp-adaptiveform-dateinput:focus"/>
                        <disabled
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Disabled"
                            cssSelector=".cmp-adaptiveform-dateinput[data-cmp-enabled='false']"/>
                        <hover
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Hover"
                            cssSelector=".cmp-adaptiveform-dateinput:hover"/>
                        <mandatory
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Mandatory"
                            cssSelector=".cmp-adaptiveform-dateinput[data-cmp-required='true']"/>
                        <error
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Error"
                            cssSelector=".cmp-adaptiveform-dateinput[data-cmp-valid='false']"/>
                        <success
                            jcr:primaryType="nt:unstructured"
                            jcr:title="Success"
                            cssSelector=".cmp-adaptiveform-dateinput[data-cmp-valid='true']"/>
                    </states>
                </widgetAndText>
            </items>
        </field>
    </items>
</jcr:root>
