<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    xmlns:granite="http://www.adobe.com/jcr/granite/1.0"
    xmlns:cq="http://www.day.com/jcr/cq/1.0"
    xmlns:jcr="http://www.jcp.org/jcr/1.0"
    xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="Adaptive Form Date Input"
    sling:resourceType="cq/gui/components/authoring/dialog"
    extraClientlibs="[core.forms.components.dateinput.v1.editor]"
    trackingFeature="core-components:adaptiveform-dateinput:v1">
    <content
        granite:class="cmp-adaptiveform-dateinput__editdialog"
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/tabs"
                maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">
                    <basic
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Basic"
                        sling:resourceType="granite/ui/components/coral/foundation/container"
                        active="{Boolean}true"
                        selected="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <columns
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                                margin="{Boolean}true">
                                <items jcr:primaryType="nt:unstructured">
                                    <column
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/container">
                                        <items jcr:primaryType="nt:unstructured">
                                            <base_dialog
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/include"
                                                path="core/fd/components/form/base/v1/base/cq:dialog/content/items/tabs/items/basic/items/columns/items/column/items"/>
                                            <default
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                fieldDescription="Enter the default date in YYYY-MM-DD format."
                                                fieldLabel="Default date"
                                                name="./default"/>
                                            <fieldType
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                name="./fieldType"
                                                required="{Boolean}true"
                                                granite:hidden="true">
                                                <items jcr:primaryType="nt:unstructured">
                                                    <item jcr:primaryType="nt:unstructured"
                                                          text="Date Input"
                                                          value="date-input"
                                                          selected="{Boolean}true"/>
                                                </items>
                                            </fieldType>
                                            <!-- Date Format — XFA picture-clause values matching foundation guidedateinput -->
                                            <dateDisplayFormat
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/select"
                                                fieldLabel="Date Format"
                                                fieldDescription="Controls the display order of day, month, and year fields."
                                                name="./dateDisplayFormat"
                                                translateOptions="{Boolean}false">
                                                <items jcr:primaryType="nt:unstructured">
                                                    <mdy jcr:primaryType="nt:unstructured"
                                                         text="MM-DD-YYYY"
                                                         value="date{M/D/YYYY}"/>
                                                    <dmy jcr:primaryType="nt:unstructured"
                                                         text="DD-MM-YYYY"
                                                         value="date{D/M/YYYY}"
                                                         selected="{Boolean}true"/>
                                                    <ymd jcr:primaryType="nt:unstructured"
                                                         text="YYYY-MM-DD"
                                                         value="date{YYYY/M/D}"/>
                                                </items>
                                            </dateDisplayFormat>
                                        </items>
                                    </column>
                                </items>
                            </columns>
                        </items>
                        <parentConfig jcr:primaryType="nt:unstructured" active="{Boolean}true"/>
                    </basic>
                    <validation
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Validation"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <columns
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                                margin="{Boolean}true">
                                <items jcr:primaryType="nt:unstructured">
                                    <column
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/container">
                                        <items jcr:primaryType="nt:unstructured">
                                            <minimum
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/datepicker"
                                                fieldDescription="Minimum allowed date (inclusive by default)."
                                                fieldLabel="Minimum date"
                                                name="./minimumDate"
                                                valueFormat="YYYY-MM-DD[T]HH:mm:ss.000-00:00"/>
                                            <minimumMessage
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textarea"
                                                fieldDescription="Error shown when the entered date is before the minimum."
                                                fieldLabel="Minimum error message"
                                                name="./minimumMessage"/>
                                            <excludeMinimum
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                                text="Exclude minimum value"
                                                fieldLabel="Exclude Minimum"
                                                value="true"
                                                name="./excludeMinimum"/>
                                            <excludeMinimum-typehint
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/hidden"
                                                name="./excludeMinimum@TypeHint"
                                                value="Boolean"/>
                                            <maximum
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/datepicker"
                                                fieldDescription="Maximum allowed date (inclusive by default)."
                                                fieldLabel="Maximum date"
                                                name="./maximumDate"
                                                valueFormat="YYYY-MM-DD[T]HH:mm:ss.000-00:00"/>
                                            <maximumMessage
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/textarea"
                                                fieldDescription="Error shown when the entered date is after the maximum."
                                                fieldLabel="Maximum error message"
                                                name="./maximumMessage"/>
                                            <excludeMaximum
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                                text="Exclude maximum value"
                                                fieldLabel="Exclude Maximum"
                                                value="true"
                                                name="./excludeMaximum"/>
                                            <excludeMaximum-typehint
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/hidden"
                                                name="./excludeMaximum@TypeHint"
                                                value="Boolean"/>
                                        </items>
                                    </column>
                                </items>
                            </columns>
                        </items>
                    </validation>
                    <!-- Title and Placeholder tab — mirrors foundation TitleAndPlaceholder fieldset -->
                    <titleandplaceholder
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Title and Placeholder"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <columns
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                                margin="{Boolean}true">
                                <items jcr:primaryType="nt:unstructured">
                                    <column
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/container">
                                        <items jcr:primaryType="nt:unstructured">
                                            <dayGroup
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/container">
                                                <items jcr:primaryType="nt:unstructured">
                                                    <titleDay
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                        emptyText="Title"
                                                        fieldLabel="Day title"
                                                        name="./titleDay"/>
                                                    <placeholderDay
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                        emptyText="Placeholder"
                                                        fieldLabel="Day placeholder"
                                                        name="./placeholderDay"/>
                                                </items>
                                            </dayGroup>
                                            <monthGroup
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/container">
                                                <items jcr:primaryType="nt:unstructured">
                                                    <titleMonth
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                        emptyText="Title"
                                                        fieldLabel="Month title"
                                                        name="./titleMonth"/>
                                                    <placeholderMonth
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                        emptyText="Placeholder"
                                                        fieldLabel="Month placeholder"
                                                        name="./placeholderMonth"/>
                                                </items>
                                            </monthGroup>
                                            <yearGroup
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/container">
                                                <items jcr:primaryType="nt:unstructured">
                                                    <titleYear
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                        emptyText="Title"
                                                        fieldLabel="Year title"
                                                        name="./titleYear"/>
                                                    <placeholderYear
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                        emptyText="Placeholder"
                                                        fieldLabel="Year placeholder"
                                                        name="./placeholderYear"/>
                                                </items>
                                            </yearGroup>
                                            <hideTitleDate
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                                text="Hide titles for day, month, and year fields"
                                                fieldLabel="Hide sub-field titles"
                                                value="true"
                                                name="./hideTitleDate"/>
                                            <hideTitleDate-typehint
                                                jcr:primaryType="nt:unstructured"
                                                sling:resourceType="granite/ui/components/coral/foundation/form/hidden"
                                                name="./hideTitleDate@TypeHint"
                                                value="Boolean"/>
                                        </items>
                                    </column>
                                </items>
                            </columns>
                        </items>
                    </titleandplaceholder>
                    <formats
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Formats"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <columns
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                                margin="{Boolean}true">
                                <items jcr:primaryType="nt:unstructured">
                                    <column
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/container">
                                        <items jcr:primaryType="nt:unstructured">
                                            <displayPatternGroup
                                                jcr:primaryType="nt:unstructured"
                                                jcr:title="Display Format"
                                                sling:resourceType="fd/af/authoring/components/granite/form/fieldset"
                                                title="Display Format">
                                                <items jcr:primaryType="nt:unstructured">
                                                    <displayPictureClause
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                        fieldDescription="The format in which the combined value will be displayed to the user."
                                                        fieldLabel="Format"
                                                        name="./displayFormat"/>
                                                </items>
                                            </displayPatternGroup>
                                            <editPatternGroup
                                                jcr:primaryType="nt:unstructured"
                                                jcr:title="Value Format"
                                                sling:resourceType="fd/af/authoring/components/granite/form/fieldset"
                                                title="Value Format">
                                                <items jcr:primaryType="nt:unstructured">
                                                    <editFormat
                                                        jcr:primaryType="nt:unstructured"
                                                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                        fieldDescription="The format in which the value is stored (e.g. YYYY-MM-DD)."
                                                        fieldLabel="Value Format"
                                                        name="./editFormat"/>
                                                </items>
                                            </editPatternGroup>
                                        </items>
                                    </column>
                                </items>
                            </columns>
                        </items>
                    </formats>
                    <help
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Help Content"
                        sling:resourceType="granite/ui/components/coral/foundation/include"
                        path="core/fd/components/form/base/v1/base/cq:dialog/content/items/tabs/items/help"/>
                    <accessibility
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Accessibility"
                        sling:resourceType="granite/ui/components/coral/foundation/include"
                        path="core/fd/components/form/base/v1/base/cq:dialog/content/items/tabs/items/accessibility"/>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
