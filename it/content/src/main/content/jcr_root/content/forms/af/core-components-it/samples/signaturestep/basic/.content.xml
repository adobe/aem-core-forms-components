<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:fd="http://www.adobe.com/aemfd/fd/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        cq:deviceGroups="[/etc/mobile/groups/responsive]"
        cq:lastModified="{Date}2024-11-01T10:00:00.000+05:30"
        cq:lastModifiedBy="admin"
        cq:template="/conf/core-components-examples/settings/wcm/templates/af-blank-v2"
        jcr:language="en"
        jcr:primaryType="cq:PageContent"
        jcr:title="signature step form"
        sling:resourceType="forms-components-examples/components/page">
        <guideContainer
            fd:version="2.1"
            jcr:primaryType="nt:unstructured"
            sling:resourceType="forms-components-examples/components/form/container"
            dorType="none"
            fieldType="form"
            schemaType="none"
            thankYouOption="page"
            themeRef="/libs/fd/af/themes/canvas"
            title="Signature Step Form">
            <wizard
                jcr:primaryType="nt:unstructured"
                jcr:title="Multi-step Form"
                sling:resourceType="forms-components-examples/components/form/tabsontop"
                enabled="{Boolean}true"
                fieldType="panel"
                hideTitle="false"
                name="wizard1730000010000"
                id="wizard_signaturestep_id"
                readOnly="{Boolean}false"
                repeatable="false"
                textIsRich="[true,true]"
                visible="{Boolean}true"
                wrapData="{Boolean}false">
                <details_panel
                    jcr:primaryType="nt:unstructured"
                    jcr:title="Details"
                    sling:resourceType="forms-components-examples/components/form/panelcontainer"
                    enabled="{Boolean}true"
                    fieldType="panel"
                    hideTitle="false"
                    name="panelcontainer1730000010001"
                    id="details_panel_sign_id"
                    readOnly="{Boolean}false"
                    repeatable="false"
                    textIsRich="[true,true,true]"
                    visible="{Boolean}true"
                    wrapData="{Boolean}false">
                    <textinput
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Full Name"
                        sling:resourceType="forms-components-examples/components/form/textinput"
                        enabled="{Boolean}true"
                        fieldType="text-input"
                        hideTitle="false"
                        name="textinput1730000010002"
                        id="fullname_sign_id"
                        readOnly="{Boolean}false"
                        required="true"
                        textIsRich="[true,true,true]"
                        unboundFormElement="{Boolean}false"
                        visible="{Boolean}true"/>
                </details_panel>
                <signature_panel
                    jcr:primaryType="nt:unstructured"
                    jcr:title="Sign Document"
                    sling:resourceType="forms-components-examples/components/form/panelcontainer"
                    enabled="{Boolean}true"
                    fieldType="panel"
                    hideTitle="false"
                    name="panelcontainer1730000010003"
                    id="signature_panel_id"
                    readOnly="{Boolean}false"
                    repeatable="false"
                    textIsRich="[true,true,true]"
                    visible="{Boolean}true"
                    wrapData="{Boolean}false">
                    <signaturestep
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Signature Step"
                        sling:resourceType="forms-components-examples/components/form/signaturestep"
                        signingService="echosign"
                        displayMsg="Loading document..."
                        fd:targetVersion="1.1"
                        fieldType="plain-text"
                        name="signaturestep1730000010004"
                        id="signaturestep_id"
                        visible="{Boolean}true"/>
                </signature_panel>
            </wizard>
        </guideContainer>
    </jcr:content>
</jcr:root>
