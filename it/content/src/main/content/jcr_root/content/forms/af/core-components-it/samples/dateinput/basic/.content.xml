<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:fd="http://www.adobe.com/aemfd/fd/1.0"
          jcr:primaryType="cq:Page">
    <jcr:content
            cq:deviceGroups="[mobile/groups/responsive]"
            cq:template="/conf/core-components-examples/settings/wcm/templates/af-blank-v2"
            fd:ignoreTranslationInvalidation="{Boolean}true"
            jcr:language="en"
            jcr:primaryType="cq:PageContent"
            jcr:title="Adaptive Form Date Input (IT)"
            sling:configRef="/conf/forms/core-components-it/samples/dateinput/basic/"
            sling:resourceType="forms-components-examples/components/page">
        <guideContainer
                fd:version="2.1"
                jcr:primaryType="nt:unstructured"
                sling:resourceType="forms-components-examples/components/form/container"
                clientLibRef="corecomponent.it.customfunction"
                dorType="none"
                fieldType="form"
                schemaType="none"
                thankYouMessage="Thank you for submitting the form."
                thankYouOption="page"
                themeRef="/libs/fd/af/themes/canvas">
            <dateinput1
                    jcr:primaryType="nt:unstructured"
                    jcr:title="Date Input 1"
                    sling:resourceType="forms-components-examples/components/form/dateinput"
                    fieldType="date-input"
                    minimumDate="{Date}2022-01-01T00:00:00.000Z"
                    name="dateinput1">
                <fd:events
                        jcr:primaryType="nt:unstructured"
                        change="[if(contains($event.payload.changes[].propertyName\, 'value')\, if($field == '2022-12-23'\, dispatchEvent(dateinput3\, 'custom:setProperty'\, {visible : true()})\, {})\, {}),if(contains($event.payload.changes[].propertyName\, 'value')\, if($field == '2022-12-23'\, dispatchEvent(dateinput4\, 'custom:setProperty'\, {visible : false()})\, {})\, {}),if(contains($event.payload.changes[].propertyName\, 'value')\, if($field == '2023-01-01'\, dispatchEvent(dateinput2\, 'custom:setProperty'\, {enabled : true()})\, {})\, {}),if(contains($event.payload.changes[].propertyName\, 'value')\, if($field == '2023-01-01'\, dispatchEvent(dateinput4\, 'custom:setProperty'\, {enabled : false()})\, {})\, {})]"/>
            </dateinput1>
            <dateinput2
                    jcr:primaryType="nt:unstructured"
                    jcr:title="Date Input 2"
                    sling:resourceType="forms-components-examples/components/form/dateinput"
                    enabled="{Boolean}false"
                    fieldType="date-input"
                    name="dateinput2"
                    visible="{Boolean}true"/>
            <dateinput3
                    jcr:primaryType="nt:unstructured"
                    jcr:title="Date Input 3"
                    sling:resourceType="forms-components-examples/components/form/dateinput"
                    enabled="{Boolean}true"
                    fieldType="date-input"
                    name="dateinput3"
                    visible="{Boolean}false"/>
            <dateinput4
                    jcr:primaryType="nt:unstructured"
                    jcr:title="Date Input 4"
                    sling:resourceType="forms-components-examples/components/form/dateinput"
                    description="This is long description"
                    fieldType="date-input"
                    id="tooltip_scenario_test"
                    name="dateinput4"
                    tooltip="This is short description"
                    tooltipVisible="true"
                    visible="{Boolean}true"/>
            <dateinput5
                    jcr:primaryType="nt:unstructured"
                    jcr:title="Date Input 5"
                    sling:resourceType="forms-components-examples/components/form/dateinput"
                    enabled="{Boolean}true"
                    fieldType="date-input"
                    name="dateinput5"
                    visible="{Boolean}true"/>
            <dateinput6
                    jcr:primaryType="nt:unstructured"
                    jcr:title="Date Input 6"
                    sling:resourceType="forms-components-examples/components/form/dateinput"
                    enabled="{Boolean}true"
                    fieldType="date-input"
                    name="dateinput6"
                    visible="{Boolean}true">
                <fd:events
                        jcr:primaryType="nt:unstructured"
                        change="[if($field == '2023-01-12'\, dispatchEvent(dateinput4\, 'custom:setProperty'\, {value : '2023-01-01'})\, {}),if($field == '2023-01-12'\, dispatchEvent(dateinput1\, 'custom:setProperty'\, {value : `null`})\, {})]"/>
            </dateinput6>
        </guideContainer>
    </jcr:content>
</jcr:root>
